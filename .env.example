# ─── Base de datos (PostgreSQL) ───────────────────────────────
# Neon: el panel da una cadena "pooled" (con -pooler en el host).
#   DATABASE_URL = pooled + "?sslmode=require&pgbouncer=true"
#   DIRECT_URL   = la misma sin "-pooler" + "?sslmode=require"  (para migraciones)
DATABASE_URL="postgresql://USER:PASS@ep-xxx-pooler.REGION.aws.neon.tech/db?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://USER:PASS@ep-xxx.REGION.aws.neon.tech/db?sslmode=require"
#
# Supabase: usá la cadena del "Session pooler" (IPv4) para ambas.
# DATABASE_URL="postgresql://postgres.REF:PASS@aws-0-REGION.pooler.supabase.com:5432/postgres"
# DIRECT_URL="postgresql://postgres.REF:PASS@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ─── Redis (cola BullMQ — Fase 2, usar Upstash) ───────────────
# REDIS_URL="rediss://default:TOKEN@HOST.upstash.io:6379"

# ─── API ──────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Autenticación del panel ──────────────────────────────────
JWT_SECRET="cambia-esto-en-produccion"

# ─── WhatsApp Cloud API (Fase 2) ──────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_VERIFY_TOKEN=""
WHATSAPP_APP_SECRET=""

# ─── LLM (Fase 2) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=""
LLM_MODEL="claude-opus-4-8"

# ─── Wompi (Fase 3) ───────────────────────────────────────────
WOMPI_PUBLIC_KEY=""
WOMPI_PRIVATE_KEY=""
WOMPI_EVENTS_SECRET=""

# ─── Domicilios ───────────────────────────────────────────────
# Punto de partida de las rutas (ubicación del local). Default: centro de Medellín.
BAKERY_LAT=6.2442
BAKERY_LNG=-75.5812

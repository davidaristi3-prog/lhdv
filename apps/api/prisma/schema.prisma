// Modelo de datos — La Hora del Venado
// Importes en COP como enteros de pesos (sin centavos). Ver packages/shared/money.ts

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (PgBouncer) — para la app
  directUrl = env("DIRECT_URL") // conexión directa — para migraciones
}

// ─── Enums ────────────────────────────────────────────────────

enum UserRole {
  OWNER // dueña
  KITCHEN // cocina
  SALES // ventas
  DELIVERY // domicilios
}

enum OrderChannel {
  WHATSAPP
  MANUAL
  RAPPI
}

// Refleja packages/shared/order-status.ts (mantener en sincronía)
enum OrderStatus {
  DRAFT
  PENDING_CONFIRMATION
  AWAITING_PAYMENT
  CONFIRMED
  IN_PRODUCTION
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  NEEDS_HUMAN
}

enum DeliveryType {
  PICKUP // recoge en el local
  OWN_COURIER // mensajero propio
  EXPRESS_APP // Uber / domicilio rápido
}

enum PaymentProvider {
  WOMPI
  BANCOLOMBIA_TRANSFER
  CASH
}

enum PaymentStatus {
  PENDING
  APPROVED
  DECLINED
  VOIDED
}

enum WebhookSource {
  WHATSAPP
  WOMPI
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

// ─── Usuarios del panel ───────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole
  active       Boolean  @default(true)
  // Solo aplican a domiciliarios (role DELIVERY); null para el resto.
  vehicle       CourierVehicle?
  capacityLimit Int? // tope de carga ponderada por ruta; null = sin límite
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdOrders      Order[]             @relation("OrderCreatedBy")
  statusEvents       OrderStatusEvent[]
  expenses           Expense[]
  courierRoutes      DeliveryRoute[]     @relation("CourierRoutes")
  zoneRates          CourierZoneRate[]
  deliveries         Order[]             @relation("OrderDeliveredBy")
  settlements        CourierSettlement[] @relation("CourierSettlements")
  createdSettlements CourierSettlement[] @relation("SettlementCreatedBy")
}

// ─── Clientes ─────────────────────────────────────────────────

model Customer {
  id            String    @id @default(cuid())
  whatsappPhone String    @unique
  name          String?
  notes         String?
  discountPercent Int? // % de descuento del cliente (mayorista); null/0 = sin descuento
  taxId         String? // CC o NIT del cliente (opcional; necesario para cuenta de cobro)
  consentAt     DateTime? // Habeas Data (Ley 1581): cuándo aceptó tratamiento de datos
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  orders    Order[]
  messages  ConversationMessage[]
  addresses CustomerAddress[]
}

// Agenda de direcciones del cliente (se eligen al crear un pedido).
model CustomerAddress {
  id         String    @id @default(cuid())
  customerId String
  label      String? // "Casa", "Trabajo", etc. (opcional)
  address    String
  zone       String? // zona de domicilio
  notes      String? // referencias: "dejar en portería", etc.
  lat        Float? // coordenadas geocodificadas (OpenStreetMap)
  lng        Float?
  geocodedAt DateTime?
  createdAt  DateTime  @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orders   Order[]

  @@index([customerId])
}

// ─── Catálogo ─────────────────────────────────────────────────

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String?
  isSeasonal  Boolean  @default(false)
  active      Boolean  @default(true)
  shelfLifeDays Int? // vida útil en días para control de vencimiento (null = no vence)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  variants ProductVariant[]
}

model ProductVariant {
  id           String  @id @default(cuid())
  productId    String
  name         String // p.ej. "Mediana"
  weightGrams  Int? // peso por tamaño (material pendiente de la propietaria)
  capacityLoad Float   @default(1) // carga en "tortas grandes" equivalentes (grande=1, mediana=0.5…)
  priceCop     Int // precio al cliente final
  wholesalePriceCop Int? // precio a vendedor/mayorista (opcional)
  active       Boolean @default(true)
  // Stock de producto terminado (hecho por adelantado, listo para vender sin pasar por cocina).
  parStock     Int     @default(0) // objetivo: cuántos mantener siempre listos (0 = se hace por pedido)
  readyStock   Int     @default(0) // existencias terminadas disponibles ahora

  product           Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems        OrderItem[]
  recipeItems       RecipeItem[]
  finishedMovements FinishedStockMovement[]
  stockBatches      StockBatch[]

  @@unique([productId, name])
}

model Addition {
  id         String  @id @default(cuid())
  name       String  @unique
  priceCop   Int
  active     Boolean @default(true)

  orderItemAdditions OrderItemAddition[]
}

// ─── Pedidos ──────────────────────────────────────────────────

model Order {
  id              String        @id @default(cuid())
  code            String?       @unique // LHDV-0001; null mientras es borrador (se asigna al entrar a cocina)
  customerId      String
  channel         OrderChannel
  status          OrderStatus   @default(DRAFT)
  isCustom        Boolean       @default(false) // estándar (bot) vs personalizado (humano)
  isStockProduction Boolean     @default(false) // pedido interno para reponer stock de producto terminado
  freeReason        String? // 'GIFT' | 'WARRANTY': pedido sin cobro (mueve inventario, no genera ingreso)
  deliveryType      DeliveryType?
  deliveryDate      DateTime?
  deliveryAddress   String? // snapshot de la dirección al momento del pedido
  deliveryZone      String?
  customerAddressId String? // dirección de la agenda del cliente que se usó (si aplica)
  deliveryCostCop   Int           @default(0)
  routeId           String? // ruta de domicilio a la que pertenece
  routeSeq          Int? // posición dentro de la ruta (orden de entrega)
  deliveredAt       DateTime?
  deliveryPhotoPath String? // foto de evidencia de entrega
  deliveredByCourierId String? // snapshot del domiciliario que entregó
  courierPayCop        Int? // snapshot del pago al domiciliario por esta entrega
  settlementId         String? // liquidación que ya pagó este pedido (one-shot)
  inventoryDeductedAt  DateTime? // cuándo se descontó el inventario (idempotencia)
  subtotalCop     Int           @default(0)
  totalCop        Int           @default(0)
  notes           String?
  createdById     String? // usuario del panel si el pedido es manual
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  customer        Customer           @relation(fields: [customerId], references: [id])
  createdBy       User?              @relation("OrderCreatedBy", fields: [createdById], references: [id])
  customerAddress CustomerAddress?   @relation(fields: [customerAddressId], references: [id], onDelete: SetNull)
  route           DeliveryRoute?     @relation(fields: [routeId], references: [id], onDelete: SetNull)
  deliveredByCourier User?           @relation("OrderDeliveredBy", fields: [deliveredByCourierId], references: [id])
  settlement      CourierSettlement? @relation(fields: [settlementId], references: [id], onDelete: SetNull)
  items           OrderItem[]
  payments        Payment[]
  statusEvents    OrderStatusEvent[]

  @@index([status])
  @@index([deliveryDate])
  @@index([settlementId])
  @@index([deliveredByCourierId])
}

model OrderItem {
  id               String  @id @default(cuid())
  orderId          String
  productVariantId String
  quantity         Int     @default(1)
  unitPriceCop     Int // snapshot del precio al momento del pedido
  customText       String? // letras / diseño
  notes            String?
  fromStockQty     Int     @default(0) // unidades del renglón cubiertas desde el stock terminado (el resto se produce)

  order     Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant   ProductVariant      @relation(fields: [productVariantId], references: [id])
  additions OrderItemAddition[]
}

model OrderItemAddition {
  id          String @id @default(cuid())
  orderItemId String
  additionId  String
  priceCop    Int // snapshot
  quantity    Int    @default(1)

  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  addition  Addition  @relation(fields: [additionId], references: [id])
}

// Auditoría de la máquina de estados: cada cambio queda registrado.
model OrderStatusEvent {
  id         String       @id @default(cuid())
  orderId    String
  fromStatus OrderStatus?
  toStatus   OrderStatus
  byUserId   String? // null = sistema (bot, webhook de pago)
  reason     String?
  photoPath  String? // evidencia opcional del evento (p.ej. foto de la baja)
  createdAt  DateTime     @default(now())

  order  Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  byUser User? @relation(fields: [byUserId], references: [id])

  @@index([orderId])
}

// ─── Pagos ────────────────────────────────────────────────────

model Payment {
  id                String          @id @default(cuid())
  orderId           String
  provider          PaymentProvider
  status            PaymentStatus   @default(PENDING)
  amountCop         Int
  providerReference String? // id de transacción en Wompi
  idempotencyKey    String?         @unique // evita confirmar dos veces el mismo pago
  rawPayload        Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

// ─── Idempotencia de webhooks entrantes (WhatsApp / Wompi) ────

model WebhookEvent {
  id          String        @id @default(cuid())
  source      WebhookSource
  externalId  String // id del evento en el origen
  payload     Json
  receivedAt  DateTime      @default(now())
  processedAt DateTime?

  @@unique([source, externalId]) // idempotencia: un evento se procesa una sola vez
}

// ─── Conversaciones (Fase 2) ──────────────────────────────────

model ConversationMessage {
  id          String           @id @default(cuid())
  customerId  String
  direction   MessageDirection
  waMessageId String?          @unique
  body        String?
  raw         Json?
  createdAt   DateTime         @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

// ─── Cupo por fecha (Fase 2 mínimo, Fase 4 completo) ──────────

model DateCapacity {
  id        String   @id @default(cuid())
  date      DateTime @unique @db.Date
  maxOrders Int?
  maxUnits  Int?
  notes     String?
}

// Zonas de domicilio (Área Metropolitana del Valle de Aburrá). El costo se asigna
// por zona; `aliases` son barrios/sectores para detectar la zona desde la dirección.
model DeliveryZone {
  id              String   @id @default(cuid())
  name            String   @unique
  deliveryCostCop Int
  aliases         String[] @default([])
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())

  courierRates CourierZoneRate[]
}

enum RouteStatus {
  DRAFT // armándose
  IN_PROGRESS // domiciliario en ruta
  DONE // todas las entregas cerradas
}

// Ruta de domicilios: agrupa pedidos para un domiciliario, en orden de entrega.
model DeliveryRoute {
  id         String      @id @default(cuid())
  date       DateTime    @db.Date
  courierId  String?
  status     RouteStatus @default(DRAFT)
  courierLat Float? // última posición reportada del domiciliario
  courierLng Float?
  courierAt  DateTime?
  createdAt  DateTime    @default(now())

  courier User?   @relation("CourierRoutes", fields: [courierId], references: [id])
  orders  Order[]

  @@index([date])
}

// ─── Contabilidad de gestión ──────────────────────────────────

enum ExpenseCategory {
  INGREDIENTS // insumos
  RENT // arriendo
  PAYROLL // nómina
  UTILITIES // servicios públicos
  DELIVERY // domicilios / transporte
  PACKAGING // empaques
  MARKETING
  FEES // comisiones (Wompi, Rappi)
  OTHER
}

// Un gasto o compra. Si trae `lines` (renglones de insumos) es una COMPRA: mueve
// inventario y recalcula el costo de los insumos, y NO se cuenta como gasto del
// P&L (su costo entra vía COGS al vender). Sin renglones es un gasto normal.
model Expense {
  id          String          @id @default(cuid())
  date        DateTime        @db.Date
  category    ExpenseCategory
  description String
  amountCop   Int
  notes       String?
  invoiceNo   String? // N° de factura del proveedor (opcional)
  supplierId  String? // proveedor (opcional; las compras informales no tienen)
  recurringId String? // si se causó desde un gasto fijo (plantilla mensual)
  createdById String?
  createdAt   DateTime        @default(now())

  createdBy User?             @relation(fields: [createdById], references: [id])
  supplier  Supplier?         @relation(fields: [supplierId], references: [id])
  recurring RecurringExpense? @relation(fields: [recurringId], references: [id])
  lines     ExpenseLine[]

  @@index([date])
  @@index([category])
  @@index([supplierId])
  @@index([recurringId])
}

// Gasto fijo mensual (arriendo, nómina, internet…). Plantilla que se "causa" con
// 1 clic cada mes; el monto se confirma/ajusta en el momento y crea un Expense real.
model RecurringExpense {
  id           String          @id @default(cuid())
  description  String
  category     ExpenseCategory
  amountCop    Int // monto típico (se puede ajustar al causar)
  supplierName String? // a quién se le paga (opcional)
  dayOfMonth   Int? // día de pago típico (informativo)
  notes        String?
  active       Boolean         @default(true)
  createdAt    DateTime        @default(now())

  expenses Expense[]
}

// Directorio simple de proveedores. Se crea al vuelo desde el formulario de compra.
model Supplier {
  id        String   @id @default(cuid())
  name      String   @unique
  phone     String?
  notes     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  expenses Expense[]
}

// Renglón de insumo de una compra: dispara el movimiento de inventario y el
// recálculo de costo (promedio ponderado) del insumo correspondiente.
model ExpenseLine {
  id           String  @id @default(cuid())
  expenseId    String
  ingredientId String
  packLabel    String? // presentación informativa, ej. "2 Kilos"
  qtyBase      Float // cantidad ya convertida a la unidad base del insumo (g/ml/unidad)
  lineCop      Int // lo que costó este renglón (total)

  expense    Expense    @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  @@index([expenseId])
  @@index([ingredientId])
}

model Ingredient {
  id             String  @id @default(cuid())
  name           String  @unique
  unit           String // 'g', 'ml', 'unidad'
  costPerUnitCop Float // costo por unidad base (puede ser fraccional: $/g)
  stockQty       Float   @default(0) // existencias actuales (en `unit`)
  lowStockQty    Float? // umbral de alerta de stock bajo
  active         Boolean @default(true)

  recipeItems  RecipeItem[]
  movements    InventoryMovement[]
  expenseLines ExpenseLine[]
}

// Receta de una presentación: cuánto de cada insumo lleva → permite el costeo.
model RecipeItem {
  id               String @id @default(cuid())
  productVariantId String
  ingredientId     String
  quantity         Float // cantidad en la unidad del ingrediente

  variant    ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  ingredient Ingredient     @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([productVariantId, ingredientId])
}

// ─── Domiciliarios: vehículo, capacidad, zonas-tarifa y liquidación ───────────

enum CourierVehicle {
  MOTO
  CARRO
}

enum SettlementStatus {
  PENDING // generada, aún no pagada
  PAID // pagada al domiciliario
}

enum SettlementPeriod {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  CUSTOM // rango libre elegido por el operador
}

// Qué zonas cubre cada domiciliario y cuánto se le PAGA por entrega en cada una.
// Doble propósito: la fila = "cubre esta zona"; payCop = tarifa de pago (distinto
// de DeliveryZone.deliveryCostCop, que es lo que se le COBRA al cliente).
model CourierZoneRate {
  id        String   @id @default(cuid())
  courierId String
  zoneId    String
  payCop    Int // pago al domiciliario por entrega en esta zona
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courier User         @relation(fields: [courierId], references: [id], onDelete: Cascade)
  zone    DeliveryZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@unique([courierId, zoneId])
  @@index([zoneId])
}

// Liquidación de pago a un domiciliario por un período. Los pedidos incluidos
// quedan marcados con Order.settlementId (un pedido entra en una sola liquidación).
model CourierSettlement {
  id          String           @id @default(cuid())
  courierId   String
  status      SettlementStatus @default(PENDING)
  period      SettlementPeriod
  periodFrom  DateTime         @db.Date
  periodTo    DateTime         @db.Date
  totalCop    Int              @default(0) // snapshot al generar
  orderCount  Int              @default(0) // snapshot al generar
  notes       String?
  paidAt      DateTime?
  createdById String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  courier   User    @relation("CourierSettlements", fields: [courierId], references: [id])
  createdBy User?   @relation("SettlementCreatedBy", fields: [createdById], references: [id])
  orders    Order[]

  @@index([courierId])
  @@index([status])
}

// ─── Inventario de materias primas ────────────────────────────

enum InventoryMoveType {
  PURCHASE // compra / entrada de stock
  CONSUMPTION // consumo por producción de un pedido
  ADJUSTMENT // ajuste manual (conteo / corrección)
}

// Rastro de cómo se movió el stock de un insumo. La existencia actual vive en
// Ingredient.stockQty; esto es el historial.
model InventoryMovement {
  id           String            @id @default(cuid())
  ingredientId String
  type         InventoryMoveType
  quantity     Float // siempre positivo; el type da el signo (PURCHASE suma, CONSUMPTION resta)
  reason       String?
  orderId      String? // si vino del consumo de producción de un pedido
  expenseLineId String? // si vino de un renglón de compra (Expense con renglones)
  createdById  String?
  createdAt    DateTime          @default(now())

  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@index([ingredientId])
  @@index([orderId])
}

// ─── Inventario de producto terminado ─────────────────────────

enum FinishedMoveType {
  PRODUCTION // se produjo para stock (entra)
  SALE // lo tomó un pedido (sale)
  RETURN // un pedido que había tomado stock se canceló/devolvió (entra)
  ADJUSTMENT // ajuste manual / conteo físico
}

// Rastro del stock de producto terminado por presentación. La existencia actual
// vive en ProductVariant.readyStock; esto es el historial.
model FinishedStockMovement {
  id               String           @id @default(cuid())
  productVariantId String
  type             FinishedMoveType
  quantity         Int // siempre positivo; el type da el signo
  reason           String?
  orderId          String? // si vino de un pedido (venta o devolución)
  createdById      String?
  createdAt        DateTime         @default(now())

  variant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)

  @@index([productVariantId])
  @@index([orderId])
}

// Lote de producto terminado: cada producción para stock genera un lote con su fecha de
// vencimiento. El stock vigente de una presentación es la suma de quantity de sus lotes;
// se consume FIFO (lo más viejo primero) y se da de baja lo vencido.
model StockBatch {
  id               String    @id @default(cuid())
  productVariantId String
  quantity         Int // unidades que quedan en el lote
  producedAt       DateTime  @default(now())
  expiresAt        DateTime? // null si el producto no tiene vida útil definida
  createdById      String?
  createdAt        DateTime  @default(now())

  variant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)

  @@index([productVariantId])
  @@index([expiresAt])
}

// ─── Cuentas de cobro ─────────────────────────────────────────

// Documento generado desde un pedido. Guarda snapshots del cliente y los renglones
// para que la cuenta quede inmutable aunque el pedido o el cliente cambien después.
model Invoice {
  id              String   @id @default(cuid())
  number          Int      @unique // consecutivo (configurable desde qué número arranca)
  orderId         String?
  customerName    String
  customerTaxId   String?
  customerAddress String?
  customerPhone   String?
  items           Json // [{ quantity, name, unitPriceCop, totalCop }]
  subtotalCop     Int
  deliveryCop     Int      @default(0)
  totalCop        Int
  issuedAt        DateTime @default(now())
  createdById     String?
  createdAt       DateTime @default(now())

  @@index([number])
}

// Datos fijos de la empresa/vendedor y el próximo consecutivo (fila única, id="default").
model InvoiceSettings {
  id             String   @id @default("default")
  companyName    String   @default("La Hora del Venado")
  companyAddress String   @default("Carrera 25 #12 Sur 59 Local 101 Mall Complex los Balsos, Medellín, Colombia")
  companyContact String   @default("(311) 7203872")
  sellerName     String   @default("Camila Ortiz Echavarría")
  sellerCC       String   @default("1017236585")
  sellerRut      String   @default("96040900715-5")
  paymentInfo    String   @default("Cuenta de Ahorros Bancolombia # 85000001519 Camila Ortiz Echavarria cc: 1017236585")
  nextNumber     Int      @default(1802)
  updatedAt      DateTime @updatedAt
}

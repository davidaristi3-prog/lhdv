{
  "name": "@lhdv/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "start:dev": "dotenv -e ../../.env -- tsx watch src/main.ts",
    "db:seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "generate": "prisma generate",
    "migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "studio": "dotenv -e ../../.env -- prisma studio",
    "reset": "dotenv -e ../../.env -- prisma migrate reset"
  },
  "prisma": {
    "seed": "dotenv -e ../../.env -- tsx prisma/seed.ts"
  },
  "dependencies": {
    "@lhdv/shared": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schedule": "^6.1.3",
    "@prisma/client": "^6.2.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "multer": "^2.2.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.0",
    "dotenv-cli": "^11.0.0",
    "prisma": "^6.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}

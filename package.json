{
  "name": "lhdv",
  "version": "0.0.0",
  "private": true,
  "description": "La Hora del Venado — sistema de pedidos con IA",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "build:shared": "pnpm --filter @lhdv/shared build",
    "dev:api": "pnpm --filter @lhdv/api start:dev",
    "db:generate": "pnpm --filter @lhdv/api generate",
    "db:migrate": "pnpm --filter @lhdv/api migrate",
    "db:seed": "pnpm build:shared && pnpm --filter @lhdv/api db:seed",
    "db:studio": "pnpm --filter @lhdv/api studio",
    "db:reset": "pnpm --filter @lhdv/api reset"
  }
}
